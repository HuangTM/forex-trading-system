#!/bin/bash
# Pre-commit hook: chained gates for the firm's hypothesis-and-implementation
# discipline.
#
# Gate 1 — Pre-registration gate (HoQR §5): strategy files require a
#          corresponding markdown pre-registration before commit.
# Gate 2 — Equivalence gate (Path B P5 / CONSENSUS Q4 / R2 Amendment §A1-9):
#          strategy/sizer/engine commits must pass the engine-vs-canonical-
#          script Sharpe-equivalence test. Closes the failure mode that
#          consumed five paper-trading days on vol_target_carry.
#
# INSTALL (one-time, from project root):
#   cp tools/git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# To bypass (exceptional circumstances only):
#   git commit --no-verify
# Bypasses are logged to .fintech-org/policy-violations.jsonl by the python
# checkers themselves.

set -e

# Find Python — prefer venv, fall back to system
if [ -f ".venv/bin/python3" ]; then
    PYTHON=".venv/bin/python3"
elif command -v python3 &>/dev/null; then
    PYTHON="python3"
else
    echo "[hooks] WARNING: Python not found, skipping all gates"
    exit 0
fi

# Fail-closed policy: a missing checker file means the gate is offline.
# Per CTO 2026-04-27 ruling on Q4, silently skipping a missing checker is
# equivalent to disabling the gate. The correct response is to BLOCK the
# commit, force the operator to either restore the file or use --no-verify
# (which logs the bypass to .fintech-org/policy-violations.jsonl).

# ---------------------------------------------------------------------------
# Gate 1: pre-registration
# ---------------------------------------------------------------------------
if [ ! -f "tools/check_pre_registration.py" ]; then
    echo "[pre-reg gate] ERROR: tools/check_pre_registration.py not found."
    echo "[pre-reg gate] Gate is OFFLINE -- BLOCKING commit (fail-closed)."
    echo "[pre-reg gate] Restore the checker or bypass with: git commit --no-verify"
    exit 1
fi
if ! $PYTHON tools/check_pre_registration.py --staged; then
    exit 1
fi

# ---------------------------------------------------------------------------
# Gate 2: engine-vs-script equivalence
# ---------------------------------------------------------------------------
if [ ! -f "tools/check_equivalence_gate.py" ]; then
    echo "[equivalence gate] ERROR: tools/check_equivalence_gate.py not found."
    echo "[equivalence gate] Gate is OFFLINE -- BLOCKING commit (fail-closed)."
    echo "[equivalence gate] Restore the checker or bypass with: git commit --no-verify"
    exit 1
fi
if ! $PYTHON tools/check_equivalence_gate.py --staged; then
    exit 1
fi

exit 0
